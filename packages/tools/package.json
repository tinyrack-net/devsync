{
  "name": "@tinyrack/dotweave-tools",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "bin": {
    "dotweave-tools": "./src/cli.ts"
  },
  "imports": {
    "#tools/*.ts": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    },
    "#tools/*": {
      "types": "./src/*",
      "default": "./src/*"
    }
  },
  "scripts": {
    "cli": "bun src/cli.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "build": "bun run typecheck",
    "typecheck": "tsc -p tsconfig.json",
    "typecheck:watch": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@stricli/core": "^1.2.6",
    "consola": "^3.4.2",
    "execa": "^9.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@types/node": "^24.12.0",
    "typescript": "^6.0.2"
  }
}
