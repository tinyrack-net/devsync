{
  "name": "@tinyrack/dotweave-tools",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "bin": {
    "dotweave-tools": "./src/cli.ts"
  },
  "imports": {
    "#tools/*.ts": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    },
    "#tools/*": {
      "types": "./src/*",
      "default": "./src/*"
    }
  },
  "scripts": {
    "dev": "node --conditions=@dotweave/source src/cli.ts",
    "sea": "node --conditions=@dotweave/source src/cli.ts sea",
    "release": "node --conditions=@dotweave/source src/cli.ts release",
    "sign": "node --conditions=@dotweave/source src/cli.ts sign",
    "appimage": "node --conditions=@dotweave/source src/cli.ts appimage",
    "verify": "node --conditions=@dotweave/source src/cli.ts verify",
    "test": "NODE_OPTIONS='--conditions=@dotweave/source' vitest",
    "test:coverage": "NODE_OPTIONS='--conditions=@dotweave/source' vitest run --coverage",
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch"
  },
  "dependencies": {
    "@stricli/core": "^1.2.6",
    "consola": "^3.4.2",
    "execa": "^9.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.1.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
