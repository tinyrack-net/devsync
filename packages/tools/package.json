{
  "name": "@tinyrack/dotweave-tools",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=25.0.0"
  },
  "bin": {
    "dotweave-tools": "./src/cli.ts"
  },
  "imports": {
    "#tools/*.ts": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    },
    "#tools/*": {
      "types": "./src/*",
      "default": "./src/*"
    }
  },
  "scripts": {
    "cli": "node src/cli.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "pnpm run typecheck",
    "typecheck": "tsc -p tsconfig.json",
    "typecheck:watch": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@stricli/core": "^1.2.6",
    "consola": "^3.4.2",
    "execa": "^9.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  }
}
