---
import LanguageSelect from "@astrojs/starlight/components/LanguageSelect.astro";
import config from "virtual:starlight/user-config";
import HeaderSearch from "starlight-theme-black/overrides/Search.astro";
import ThemeSiteTitle from "starlight-theme-black/overrides/SiteTitle.astro";
import SocialIcons from "starlight-theme-black/overrides/SocialIcons.astro";
import ThemeSelect from "starlight-theme-black/overrides/ThemeSelect.astro";

const cliVersion = __CLI_VERSION__;

const shouldRenderSearch =
  config.pagefind ||
  config.components.Search !== "@astrojs/starlight/components/Search.astro";
---

<div class="site-title-wrapper">
  <div class="site-title-group">
    <ThemeSiteTitle />
    <span class="version-badge" aria-label={`Latest CLI version ${cliVersion}`}>
      v{cliVersion}
    </span>
  </div>
</div>

<button class="show-modal" popovertargetaction="toggle" popovertarget="drawer">
  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5"></path>
  </svg>
  <span class="sr-only">Toggle Menu</span>
</button>

<div class="header-right">
  {shouldRenderSearch && <HeaderSearch />}

  <nav class="header-nav">
    <div>
      <SocialIcons />
    </div>
    <div>
      <ThemeSelect />
    </div>
    <div>
      <LanguageSelect />
    </div>
  </nav>
</div>

<style>
  .site-title-wrapper {
    display: none;
    margin-right: 1rem;
  }

  @media (min-width: 768px) {
    .site-title-wrapper {
      display: flex;
    }
  }

  .site-title-group {
    align-items: center;
    display: flex;
    min-width: 0;
  }

  .version-badge {
    flex-shrink: 0;
    margin-left: 0.35rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-3) 70%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--sl-color-bg-nav) 82%, var(--sl-color-accent-high) 18%);
    color: var(--sl-color-text);
    font-size: var(--sl-text-xs);
    font-weight: 500;
    line-height: 1;
    padding: 0.3rem 0.5rem;
  }

  @media (max-width: 40rem) {
    .version-badge {
      padding-inline: 0.4rem;
    }
  }

  .show-modal {
    all: unset;
    display: inline-flex;
    margin-right: 0.5rem;
    margin-left: -0.5rem;
    height: 2rem;
    width: 2rem;
    align-items: center;
    justify-content: center;
    padding-bottom: 0.5rem;
    padding-top: 0.5rem;
    font-size: 1rem;
    line-height: 1.5rem;
  }

  @media (min-width: 768px) {
    .show-modal {
      display: none;
    }
  }

  .show-modal > svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .header-right {
    gap: 0.5rem;
    justify-content: space-between;
    align-items: center;
    flex: 1 1 0%;
    display: flex;
  }

  @media (min-width: 768px) {
    .header-right {
      justify-content: flex-end;
    }
  }

  .header-nav {
    gap: 0.125rem;
    align-items: center;
    display: flex;
  }
</style>
