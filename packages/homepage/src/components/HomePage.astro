---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import wordmark from "../assets/wordmark.svg";

type Action = {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
};

type Feature = {
  title: string;
  body: string;
  eyebrow: string;
};

type Step = {
  command: string;
  title: string;
  body: string;
};

type Capability = {
  name: string;
  body: string;
};

type Props = {
  actions: Action[];
  capabilities: Capability[];
  commandPreview: string;
  description: string;
  features: Feature[];
  intro: string;
  lang: "en" | "ko";
  sectionLabels: {
    capabilities: string;
    commandPreview: string;
    featureEyebrow: string;
    featureTitle: string;
    workflow: string;
    workflowTitle: string;
  };
  steps: Step[];
  tagline: string;
  title: string;
};

const {
  actions,
  capabilities,
  commandPreview,
  description,
  features,
  intro,
  lang,
  sectionLabels,
  steps,
  tagline,
  title,
} = Astro.props;
---

<StarlightPage frontmatter={{ title, description, template: "splash" }}>
  <main
    class="not-content text-slate-900 dark:text-slate-100"
    lang={lang}
  >
    <section
      class="border-b border-slate-900/8 bg-[radial-gradient(circle_at_top,rgba(15,118,110,0.14),transparent_32%),radial-gradient(circle_at_85%_10%,rgba(14,165,233,0.16),transparent_20%),linear-gradient(180deg,rgba(255,255,255,0.94),rgba(240,247,245,1))] dark:border-slate-200/10 dark:bg-[radial-gradient(circle_at_top,rgba(94,234,212,0.16),transparent_36%),radial-gradient(circle_at_85%_10%,rgba(56,189,248,0.12),transparent_22%),linear-gradient(180deg,rgba(10,14,23,0.96),rgba(3,7,18,1))]"
    >
      <div
        class="mx-auto grid max-w-6xl items-center gap-12 px-6 py-16 sm:px-10 sm:py-20 lg:grid-cols-[minmax(0,1.08fr)_minmax(20rem,26rem)] lg:py-24"
      >
        <div>
          <p
            class="m-0 text-[0.78rem] font-bold uppercase tracking-[0.22em] text-[var(--sl-color-accent)]"
          >
            devsync
          </p>
          <h1
            class="mt-3 max-w-[15ch] text-[clamp(2.7rem,6vw,5rem)] leading-[0.96] font-black tracking-[-0.05em]"
          >
            {tagline}
          </h1>
          <p
            class="mt-6 max-w-3xl text-[1.08rem] leading-[1.9] text-slate-600 dark:text-slate-400"
          >
            {intro}
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            {actions.map((action) => (
              <a
                class:list={[
                  "inline-flex items-center justify-center rounded-full px-5 py-3 text-sm font-bold no-underline transition duration-200 hover:-translate-y-0.5",
                  action.variant === "secondary"
                    ? "border border-slate-900/8 bg-white/60 text-slate-900 dark:border-slate-200/10 dark:bg-slate-900/35 dark:text-slate-100"
                    : "bg-[var(--sl-color-accent)] text-white hover:bg-[var(--sl-color-accent-high)]",
                ]}
                href={action.href}
              >
                {action.label}
              </a>
            ))}
          </div>
        </div>

        <div
          class="rounded-[2rem] border border-slate-900/8 bg-white/80 p-4 shadow-[0_24px_80px_rgba(15,23,42,0.08)] backdrop-blur-xl dark:border-slate-200/10 dark:bg-slate-900/70"
        >
          <div class="mb-4 flex gap-2">
            <span class="h-3 w-3 rounded-full bg-slate-400/40"></span>
            <span class="h-3 w-3 rounded-full bg-slate-400/40"></span>
            <span class="h-3 w-3 rounded-full bg-slate-400/40"></span>
          </div>
          <img
            alt="devsync"
            class="mx-auto mb-4 block w-full max-w-[18rem]"
            height="160"
            src={wordmark.src}
            width="320"
          />
          <pre
            class="m-0 overflow-auto rounded-[1.25rem] bg-[#04111f] px-4 py-5 text-[0.9rem] leading-[1.8] text-[#d7f9f4]"
          ><code>{commandPreview}</code></pre>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 pt-17 pb-4 sm:px-10">
      <div class="mb-6 max-w-3xl">
        <p
          class="m-0 text-[0.78rem] font-bold uppercase tracking-[0.22em] text-[var(--sl-color-accent)]"
        >
          {sectionLabels.featureEyebrow}
        </p>
        <h2
          class="mt-3 text-[clamp(1.8rem,4vw,3rem)] leading-[1.05] font-extrabold tracking-[-0.04em]"
        >
          {sectionLabels.featureTitle}
        </h2>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {features.map((feature) => (
          <article
            class="rounded-[1.5rem] border border-slate-900/8 bg-white/80 p-5 shadow-[0_24px_80px_rgba(15,23,42,0.08)] backdrop-blur-xl dark:border-slate-200/10 dark:bg-slate-900/70"
          >
            <p
              class="m-0 text-[0.78rem] font-bold uppercase tracking-[0.22em] text-[var(--sl-color-accent)]"
            >
              {feature.eyebrow}
            </p>
            <h3 class="mt-2 text-[1.15rem] leading-[1.35] font-bold">
              {feature.title}
            </h3>
            <p class="mt-3 leading-[1.8] text-slate-600 dark:text-slate-400">
              {feature.body}
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 pt-17 pb-4 sm:px-10">
      <div class="mb-6 max-w-3xl">
        <p
          class="m-0 text-[0.78rem] font-bold uppercase tracking-[0.22em] text-[var(--sl-color-accent)]"
        >
          {sectionLabels.workflow}
        </p>
        <h2
          class="mt-3 text-[clamp(1.8rem,4vw,3rem)] leading-[1.05] font-extrabold tracking-[-0.04em]"
        >
          {sectionLabels.workflowTitle}
        </h2>
      </div>

      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {steps.map((step, index) => (
          <article
            class="rounded-[1.5rem] border border-slate-900/8 bg-white/80 p-5 shadow-[0_24px_80px_rgba(15,23,42,0.08)] backdrop-blur-xl dark:border-slate-200/10 dark:bg-slate-900/70"
          >
            <p
              class="m-0 text-[0.82rem] font-extrabold uppercase tracking-[0.2em] text-[var(--sl-color-accent)]"
            >
              0{index + 1}
            </p>
            <code
              class="mt-3 inline-block rounded-full bg-[rgba(15,118,110,0.11)] px-3 py-1.5 text-[0.82rem] font-bold text-[var(--sl-color-accent-high)] dark:text-[#b9fff2]"
            >
              {step.command}
            </code>
            <h3 class="mt-3 text-[1.15rem] leading-[1.35] font-bold">
              {step.title}
            </h3>
            <p class="mt-3 leading-[1.8] text-slate-600 dark:text-slate-400">
              {step.body}
            </p>
          </article>
        ))}
      </div>
    </section>

    <section
      class="mx-auto grid max-w-6xl gap-4 px-6 pt-17 pb-18 sm:px-10 lg:grid-cols-[minmax(0,1fr)_minmax(20rem,28rem)]"
    >
      <div>
        <div class="mb-6 max-w-3xl">
          <p
            class="m-0 text-[0.78rem] font-bold uppercase tracking-[0.22em] text-[var(--sl-color-accent)]"
          >
            {sectionLabels.capabilities}
          </p>
          <h2
            class="mt-3 text-[clamp(1.8rem,4vw,3rem)] leading-[1.05] font-extrabold tracking-[-0.04em]"
          >
            {sectionLabels.commandPreview}
          </h2>
        </div>

        <div class="grid gap-4">
          {capabilities.map((capability) => (
            <article
              class="rounded-[1.5rem] border border-slate-900/8 bg-white/80 p-5 shadow-[0_24px_80px_rgba(15,23,42,0.08)] backdrop-blur-xl dark:border-slate-200/10 dark:bg-slate-900/70"
            >
              <h3 class="m-0 text-base font-bold">{capability.name}</h3>
              <p class="mt-3 leading-[1.8] text-slate-600 dark:text-slate-400">
                {capability.body}
              </p>
            </article>
          ))}
        </div>
      </div>

      <div
        class="rounded-[1.5rem] border border-slate-900/8 bg-white/80 p-5 shadow-[0_24px_80px_rgba(15,23,42,0.08)] backdrop-blur-xl dark:border-slate-200/10 dark:bg-slate-900/70"
      >
        <pre
          class="m-0 overflow-auto rounded-[1.25rem] bg-[#04111f] px-4 py-5 text-[0.9rem] leading-[1.8] text-[#d7f9f4]"
        ><code>{commandPreview}</code></pre>
      </div>
    </section>
  </main>
</StarlightPage>
