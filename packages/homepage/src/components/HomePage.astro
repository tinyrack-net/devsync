---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import GlobeBackground from "./GlobeBackground.astro";

type Action = {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
};

type Props = {
  actions: Action[];
  body: string;
  description: string;
  keywords: string;
  lang: "en" | "ko" | "ja";
  tagline: string;
  title: string;
};

const { actions, body, description, keywords, lang, tagline, title } = Astro.props;

const ogLocale = lang === "ko" ? "ko_KR" : lang === "ja" ? "ja_JP" : "en_US";
---

<StarlightPage
  frontmatter={{
    title,
    description,
    template: "splash",
    hero: {},
    head: [
      {
        tag: "meta",
        attrs: { name: "keywords", content: keywords },
      },
      {
        tag: "meta",
        attrs: { property: "og:locale", content: ogLocale },
      },
    ],
  }}
>
  <main class="not-content" lang={lang}>
    <section
      class="homepage-hero relative flex flex-col items-center justify-center overflow-hidden bg-[var(--background)] px-6 py-24 sm:py-32 min-h-[100dvh]"
    >
      <GlobeBackground />

      <div
        class="pointer-events-none absolute inset-x-0 top-0 flex justify-center opacity-0 dark:opacity-100"
      >
        <div
          class="h-[30rem] w-[64rem] rounded-full bg-teal-500/[0.06] blur-[120px]"
        >
        </div>
      </div>

      <div
        class="relative z-10 mx-auto flex max-w-3xl flex-col items-center gap-8 text-center"
      >
        <div
          class="inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-zinc-50 px-4 py-1.5 dark:border-white/10 dark:bg-white/[0.03]"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-teal-500 dark:bg-teal-400"
          ></span>
          <span
            class="font-mono text-[0.68rem] uppercase tracking-[0.22em] text-zinc-500"
            >Devsync</span
          >
        </div>

        <h1
          class="m-0 max-w-[18ch] text-[clamp(2.6rem,7vw,4.5rem)] font-bold leading-[1.05] tracking-tight text-zinc-900 [text-shadow:0_2px_24px_rgba(0,0,0,0.10)] dark:text-white dark:[text-shadow:0_2px_32px_rgba(0,0,0,0.60)]"
        >
          {tagline}
        </h1>

        <p
          class="m-0 max-w-md whitespace-pre-line text-base leading-relaxed text-zinc-500 [text-shadow:0_1px_12px_rgba(0,0,0,0.08)] sm:text-lg dark:text-zinc-400 dark:[text-shadow:0_1px_16px_rgba(0,0,0,0.50)]"
        >
          {body}
        </p>

        <div class="flex flex-wrap items-center justify-center gap-3">
          {
            actions.map((action) => (
              <a
                class:list={[
                  "inline-flex items-center rounded-md px-5 py-2.5 text-sm font-medium no-underline transition-opacity hover:opacity-75",
                  action.variant === "secondary"
                    ? "border border-zinc-200 bg-white text-zinc-700 dark:border-white/10 dark:bg-white/[0.05] dark:text-zinc-300"
                    : "bg-zinc-900 text-white dark:bg-white dark:text-zinc-950",
                ]}
                href={action.href}
              >
                {action.label}
              </a>
            ))
          }
        </div>

        <!-- Terminal showcase -->
        <div
          class="mt-6 w-full max-w-sm overflow-hidden rounded-xl border border-zinc-200 bg-zinc-950 text-left shadow-2xl sm:max-w-md dark:border-white/[0.08]"
        >
          <div
            class="flex items-center gap-1.5 border-b border-white/[0.06] px-4 py-2.5"
          >
            <span class="h-2 w-2 rounded-full bg-zinc-700"></span>
            <span class="h-2 w-2 rounded-full bg-zinc-700"></span>
            <span class="h-2 w-2 rounded-full bg-zinc-700"></span>
          </div>
          <div class="space-y-2.5 p-4 font-mono text-[0.78rem] leading-relaxed">
            <div>
              <div>
                <span class="text-teal-400">❯</span><span class="text-zinc-300">
                  devsync track ~/.zshrc ~/.gitconfig</span
                >
              </div>
              <div class="pl-4 text-zinc-500">
                ✓ Tracking .zshrc .gitconfig
              </div>
            </div>
            <div>
              <div>
                <span class="text-teal-400">❯</span><span class="text-zinc-300">
                  devsync push</span
                >
              </div>
              <div class="pl-4 text-zinc-500">
                ✓ .zshrc .gitconfig .vimrc synced
              </div>
            </div>
            <div>
              <div>
                <span class="text-teal-400">❯</span><span class="text-zinc-300">
                  devsync pull</span
                >
              </div>
              <div class="pl-4 text-zinc-500">✓ All configs restored</div>
            </div>
            <div>
              <span class="text-teal-400">❯</span><span
                class="terminal-cursor ml-0.5 inline-block w-1.5 text-zinc-500"
                >▎</span
              >
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</StarlightPage>

<style is:global>
  /* Break .homepage-hero out of Starlight's ContentPanel / sl-container constraints */
  body:has(.homepage-hero) .content-panel {
    padding: 0;
  }
  body:has(.homepage-hero) .sl-container {
    max-width: 100%;
    margin-inline: 0;
    width: 100%;
  }
  body:has(.homepage-hero) [data-pagefind-body] {
    padding-bottom: 0;
  }
  /* Remove Starlight's sl-markdown-content spacing rules */
  body:has(.homepage-hero) .sl-markdown-content > * + * {
    margin-top: 0;
  }
  /* Remove theme's markdown-wrapper padding on the landing page */
  body:has(.homepage-hero) .markdown-wrapper {
    padding-top: 0;
    padding-bottom: 0;
  }
  /* Make the flex chain from main.main down to the hero section fill available height */
  body:has(.homepage-hero) main.main > main,
  body:has(.homepage-hero) .markdown-wrapper,
  body:has(.homepage-hero) .sl-markdown-content,
  body:has(.homepage-hero) .not-content {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  body:has(.homepage-hero) .homepage-hero {
    flex: 1;
  }
  /* Hide the empty Starlight footer on landing page */
  body:has(.homepage-hero) footer {
    display: none;
  }
  /* Match Starlight's page background to hero section background — prevents color seams */
  body:has(.homepage-hero) {
    background-color: var(--background);
  }
  /* Blinking terminal cursor */
  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  .terminal-cursor {
    animation: cursor-blink 1s step-end infinite;
  }
</style>
