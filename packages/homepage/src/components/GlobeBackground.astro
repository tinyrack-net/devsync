---
// Full-viewport 3D globe showing config syncing from worldwide devices to a central Git repo.
// Hub-and-spoke arc topology: every location arcs to/from the repository hub.
// Uses cobe v2 (WebGL).
---

<div class="globe-section" id="globe-section">
  <canvas id="globe-canvas"></canvas>
</div>

<script>
  import createGlobe from "cobe";

  function initGlobe() {
    const canvas = document.getElementById("globe-canvas") as HTMLCanvasElement;
    if (!canvas) return;

    const container = document.getElementById("globe-section")!;
    let phi = 0;
    let globe: ReturnType<typeof createGlobe> | null = null;
    let frameId: number | null = null;

    const locations: [number, number][] = [
      [37.56, 126.97],   // Seoul
      [35.68, 139.69],   // Tokyo
      [37.77, -122.42],  // San Francisco
      [51.51, -0.13],    // London
      [52.52, 13.41],    // Berlin
      [-33.87, 151.21],  // Sydney
      [1.35, 103.82],    // Singapore
      [49.28, -123.12],  // Vancouver
    ];

    // Hub point: center of the visible globe face (roughly North Atlantic)
    const repoHub: [number, number] = [30, -30];

    // Hub-and-spoke: every location ↔ central repo
    const teal: [number, number, number] = [0.18, 0.83, 0.75];
    const cyan: [number, number, number] = [0.22, 0.74, 0.97];
    const emerald: [number, number, number] = [0.2, 0.83, 0.6];
    const colors = [teal, cyan, emerald];

    const arcs = locations.flatMap((loc, i) => [
      { from: loc, to: repoHub, color: colors[i % 3] },
      { from: repoHub, to: loc, color: colors[(i + 1) % 3] },
    ]);

    function setup() {
      if (frameId != null) cancelAnimationFrame(frameId);
      if (globe) globe.destroy();

      const rect = container.getBoundingClientRect();
      const size = Math.max(rect.width, rect.height, 700);
      const dpr = Math.min(window.devicePixelRatio, 2);

      canvas.width = Math.round(size * dpr);
      canvas.height = Math.round(size * dpr);
      canvas.style.width = `${size}px`;
      canvas.style.height = `${size}px`;

      const isDark = document.documentElement.getAttribute("data-theme") !== "light";

      globe = createGlobe(canvas, {
        devicePixelRatio: dpr,
        width: size * dpr,
        height: size * dpr,
        phi,
        theta: 0.15,
        dark: isDark ? 1 : 0,
        diffuse: isDark ? 1.4 : 1.8,
        mapSamples: 20000,
        mapBrightness: isDark ? 3 : 6,
        baseColor: isDark ? [0.08, 0.1, 0.14] : [0.88, 0.9, 0.92],
        markerColor: [0.18, 0.83, 0.75],
        glowColor: isDark ? [0.04, 0.15, 0.15] : [0.82, 0.92, 0.92],
        markers: [
          { location: repoHub, size: 0.15 },
          ...locations.map(loc => ({ location: loc, size: 0.04 })),
        ],
        arcs,
        arcColor: teal,
        arcWidth: 0.5,
        arcHeight: 0.3,
        scale: 1.1,
        offset: [0, 0],
        opacity: isDark ? 0.95 : 0.9,
      });

      // cobe v2: drive rotation via requestAnimationFrame + globe.update()
      function animate() {
        phi += 0.005;
        globe?.update({ phi });
        frameId = requestAnimationFrame(animate);
      }
      animate();
    }

    setup();

    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener("resize", () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(setup, 250);
    });

    const observer = new MutationObserver((mutations) => {
      for (const m of mutations) {
        if (m.attributeName === "data-theme") {
          setup();
          break;
        }
      }
    });
    observer.observe(document.documentElement, { attributes: true });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initGlobe);
  } else {
    initGlobe();
  }
</script>

<style>
  /* ── Globe container ── */
  .globe-section {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  #globe-canvas {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.55;
    max-width: none;
    animation: globe-fadein 1.5s ease-out;
  }
  :global([data-theme="light"]) #globe-canvas {
    opacity: 0.35;
  }

  @keyframes globe-fadein {
    from { opacity: 0; transform: translate(-50%, -50%) scale(0.95); }
  }

</style>
