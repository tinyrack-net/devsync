{
  "name": "@tinyrack/dotweave",
  "version": "0.41.1",
  "description": "A personal CLI tool for git-backed configuration sync.",
  "type": "module",
  "license": "MIT",
  "author": "winetree94",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinyrack-net/dotweave.git"
  },
  "homepage": "https://github.com/tinyrack-net/dotweave#readme",
  "bugs": {
    "url": "https://github.com/tinyrack-net/dotweave/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cli",
    "sync",
    "dotfiles",
    "config-sync",
    "dotweave"
  ],
  "imports": {
    "#app/*.ts": {
      "@dotweave/source": "./src/*.ts",
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "bin": {
    "dotweave": "./bin/index.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsc -p tsconfig.build.json --watch",
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "pkg:build": "dotweave-tools pkg build",
    "pkg:smoke": "dotweave-tools pkg smoke --skip-build",
    "start": "node dist/index.js",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "check": "pnpm run typecheck && biome check . && pnpm run test",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "release:patch": "dotweave-tools release patch",
    "release:minor": "dotweave-tools release minor",
    "release:major": "dotweave-tools release major"
  },
  "dependencies": {
    "@stricli/core": "^1.2.6",
    "age-encryption": "^0.3.0",
    "consola": "^3.4.2",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@tinyrack/dotweave-tools": "workspace:*",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "execa": "^9.6.1",
    "node-gyp": "^12.3.0",
    "node-pty": "^1.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
