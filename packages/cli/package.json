{
  "name": "@tinyrack/dotweave",
  "version": "0.39.37",
  "description": "A personal CLI tool for git-backed configuration sync.",
  "type": "module",
  "license": "MIT",
  "author": "winetree94",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinyrack-net/dotweave.git"
  },
  "homepage": "https://github.com/tinyrack-net/dotweave#readme",
  "bugs": {
    "url": "https://github.com/tinyrack-net/dotweave/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cli",
    "sync",
    "dotfiles",
    "config-sync",
    "dotweave"
  ],
  "imports": {
    "#app/*.ts": {
      "@dotweave/source": "./src/*.ts",
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "bin": {
    "dotweave": "./bin/index.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3.13"
  },
  "scripts": {
    "dev": "tsc -p tsconfig.build.json --watch",
    "build": "tsc -p tsconfig.build.json",
    "clean": "bun -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "bun -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "sea:bundle": "dotweave-tools sea build --bundle-only",
    "sea:build": "dotweave-tools sea build",
    "sea:smoke": "dotweave-tools sea smoke --skip-build",
    "start": "bun dist/index.js",
    "prepack": "bun run build",
    "typecheck": "tsc -p tsconfig.json",
    "test": "bun test --parallel=2",
    "test:watch": "bun test --parallel=2 --watch",
    "coverage": "bun test --parallel=2 --coverage",
    "check": "bun run typecheck && biome check . && bun run test",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "release:patch": "dotweave-tools release patch",
    "release:minor": "dotweave-tools release minor",
    "release:major": "dotweave-tools release major"
  },
  "dependencies": {
    "@stricli/core": "^1.2.6",
    "age-encryption": "^0.3.0",
    "consola": "^3.4.2",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@tinyrack/dotweave-tools": "workspace:*",
    "@types/node": "^24.12.0",
    "@types/bun": "^1.3.13",
    "execa": "^9.6.1",
    "typescript": "^6.0.2"
  }
}
