{
  "name": "@tinyrack/devsync",
  "version": "1.24.0",
  "description": "A personal CLI tool for git-backed configuration sync.",
  "type": "module",
  "license": "MIT",
  "author": "winetree94",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinyrack-net/devsync.git"
  },
  "homepage": "https://github.com/tinyrack-net/devsync#readme",
  "bugs": {
    "url": "https://github.com/tinyrack-net/devsync/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cli",
    "sync",
    "dotfiles",
    "config-sync",
    "devsync"
  ],
  "imports": {
    "#app/*.ts": {
      "@devsync/source": "./src/*.ts",
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "bin": {
    "devsync": "./bin/index.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsc -p tsconfig.build.json --watch",
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "sea:bundle": "NODE_OPTIONS='--conditions=@devsync/source' node scripts/build-sea.ts --bundle-only",
    "sea:build": "NODE_OPTIONS='--conditions=@devsync/source' node scripts/build-sea.ts",
    "sea:smoke": "NODE_OPTIONS='--conditions=@devsync/source' node scripts/smoke-sea.ts",
    "start": "node dist/index.js",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "check": "pnpm run typecheck && biome check . && pnpm run test",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "release:patch": "node scripts/release.ts patch",
    "release:minor": "node scripts/release.ts minor",
    "release:major": "node scripts/release.ts major"
  },
  "dependencies": {
    "@stricli/core": "^1.2.6",
    "age-encryption": "^0.3.0",
    "consola": "^3.4.2",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.1.1",
    "execa": "^9.6.1",
    "node-pty": "^1.1.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
