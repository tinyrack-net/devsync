{
  "name": "dotweave",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm run -r --filter @tinyrack/* dev",
    "build": "pnpm run -r --filter @tinyrack/* build",
    "typecheck": "pnpm run -r --if-present --filter @tinyrack/* typecheck",
    "test": "pnpm run -r --filter @tinyrack/* test",
    "ci:validate": "pnpm run build && pnpm run typecheck && pnpm run test && pnpm run format:check",
    "format": "biome format --write .",
    "format:check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
