{
  "name": "@tinyrack/devsync",
  "version": "1.0.3",
  "description": "A personal CLI tool for git-backed configuration sync.",
  "type": "module",
  "license": "MIT",
  "author": "winetree94",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinyrack-net/devsync.git"
  },
  "homepage": "https://github.com/tinyrack-net/devsync#readme",
  "bugs": {
    "url": "https://github.com/tinyrack-net/devsync/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cli",
    "sync",
    "dotfiles",
    "config-sync",
    "devsync"
  ],
  "imports": {
    "#app/*": "./src/*"
  },
  "bin": {
    "devsync": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "oclif": {
    "bin": "devsync",
    "dirname": "devsync",
    "commands": {
      "strategy": "explicit",
      "target": "./src/cli/commands/index.ts",
      "identifier": "COMMANDS"
    },
    "topicSeparator": " ",
    "plugins": [
      "@oclif/plugin-autocomplete"
    ],
    "additionalHelpFlags": [
      "-h"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "node --watch src/index.ts",
    "start": "node src/index.ts",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "check": "npm run typecheck && biome check . && npm run test",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "release:patch": "npm version patch -m \"chore(release): %s\"",
    "release:minor": "npm version minor -m \"chore(release): %s\"",
    "release:major": "npm version major -m \"chore(release): %s\""
  },
  "dependencies": {
    "@oclif/core": "^4.9.0",
    "@oclif/plugin-autocomplete": "^3.2.41",
    "age-encryption": "^0.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "execa": "^9.6.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
