{
  "name": "dotweave",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '@tinyrack/*' dev",
    "build": "bun run --filter '@tinyrack/*' build",
    "typecheck": "bun run --filter '@tinyrack/*' typecheck",
    "test": "bun run --filter '@tinyrack/*' test",
    "ci:validate": "bun run build && bun run typecheck && bun run test && bun run format:check",
    "format": "biome format --write .",
    "format:check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10"
  },
  "engines": {
    "bun": ">=1.3.13"
  }
}
